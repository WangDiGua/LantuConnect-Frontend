# 本地 npm run dev：复制为 .env.development 或 .env（勿提交密钥）
# 仅 context-path、直连本机 8080 时用：
VITE_API_BASE_URL=/regis

# 与线上网关一致（浏览器里：网关前缀 + /regis）时用：
# VITE_API_BASE_URL=/factory_ixeo2_8oiuw/regis

# 静态资源子路径（Vite base，需与 nginx 上部署目录一致；缺省则生产包自动用网关前缀）
# VITE_APP_BASE_PATH=/factory_ixeo2_8oiuw/

# 开发代理目标（仅 Vite dev，生产构建不读）
VITE_API_PROXY_TARGET=http://localhost:8080
