# ── LantuConnect 环境变量说明 ───────────────────────────
# 复制为 .env.development 或 .env.production 使用

# 后端接口基地址
VITE_API_BASE_URL="/api"

# Mock 开关
# true  = 使用前端 Mock 数据（不需要后端，独立开发前端）
# false = 请求真实后端 API（需要启动后端服务）
VITE_USE_MOCK="true"

# Mock 模拟网络延迟（毫秒，仅 Mock 模式生效）
VITE_MOCK_DELAY_MS="300"

# localStorage Token 存储 Key
VITE_TOKEN_KEY="lantu_access_token"
VITE_REFRESH_TOKEN_KEY="lantu_refresh_token"

# 环境标识：development | staging | production
VITE_APP_ENV="development"

# 开发代理目标（关闭 Mock 后，vite dev server 将 /api 请求代理到此地址）
VITE_API_PROXY_TARGET="http://localhost:8080"
